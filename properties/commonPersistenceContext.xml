	<tx:annotation-driven transaction-manager="transactionManager" />
	<bean id="transactionManager"
		class="org.springframework.orm.hibernate3.HibernateTransactionManager"
		lazy-init="true">
		<property name="sessionFactory">
			<ref bean="enterpriseSessionFactory" />
		</property>
	</bean>



	<bean id="enterpriseHibernateTemplate" class="org.springframework.orm.hibernate3.HibernateTemplate"
		lazy-init="true">
		<property name="sessionFactory">
			<ref bean="enterpriseSessionFactory" />
		</property>
	</bean>
	<bean id="genericDao"
		class="com.tcs.framework.persistanceConfiguration.HibernateTemplateSpringGenericDAO">
		<property name="hibernateTemplate">
			<ref bean="enterpriseHibernateTemplate" />
		</property>
	</bean>


	<!-- Set up the dataSources -->
	<bean id="enterpriseDataSource" class="org.springframework.jndi.JndiObjectFactoryBean">
		<property name="jndiName">
			<value>${hibernate.connection.datasource}</value>
		</property>
	</bean>
</beans>