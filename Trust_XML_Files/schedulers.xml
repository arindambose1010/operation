 <task:annotation-driven />
 <!--  trigger for generating bank files by ishank  -->
 <bean id="claimGenerateBankFile" class="org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean">
  <property name="targetObject" ref="claimsFlowDAO" />
  <property name="targetMethod" value="generateFile" />
  <property name="concurrent" value="false"/>
</bean>
<bean id="generateTrigger" class="org.springframework.scheduling.quartz.SimpleTriggerBean">
    <property name="jobDetail" ref="claimGenerateBankFile" />
    <property name="startDelay" value="0"/> 
    <property name="repeatInterval" value="7200000"/>
</bean>
<bean class="org.springframework.scheduling.quartz.SchedulerFactoryBean">
  <property name="triggers">
   <list>
    <ref bean="generateTrigger"/>
   </list>
  </property>
 </bean> 
 

 
