 <!--Added by ramalakshmi for autocancellation cases scheduler  -->
 <bean id="AutoCancelCasesScheduler" 
 class="com.ahct.preauth.service.AutoCancelCasesScheduler"> 
   <property name="genericDao">
   <ref bean="genericDao"/>
  </property>
 </bean>
     <bean id="autoCancelCases" class="org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean">
  <property name="targetObject" ref="AutoCancelCasesScheduler" />
  <property name="targetMethod" value="cancelPendingCases" />
  <property name="concurrent" value="false"/>
</bean>
<bean id="autoCancelCasesCronTrigger" class="org.springframework.scheduling.quartz.CronTriggerBean">
    <property name="jobDetail" ref="autoCancelCases" />
      <property name="cronExpression" value="0 01 00 ? * *" />
</bean>
<bean class="org.springframework.scheduling.quartz.SchedulerFactoryBean">
  <property name="triggers">
   <list>
    <ref bean="autoCancelCasesCronTrigger"/>
   </list>
  </property>
 </bean>
 <!--End of autocancellation cases scheduler  -->
 
 
