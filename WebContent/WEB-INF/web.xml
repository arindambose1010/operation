<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://java.sun.com/xml/ns/javaee" xmlns:web="http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd" id="WebApp_ID" version="2.5">
  <display-name>Operations</display-name>
  <context-param>
    <param-name>contextConfigLocation</param-name>
    <param-value>/WEB-INF/applicationContext.xml,/WEB-INF/schedulers.xml</param-value>
  </context-param>
  <listener>
    <listener-class>org.springframework.web.context.ContextLoaderListener</listener-class>
  </listener>
  <servlet>
    <servlet-name>Operations</servlet-name>
    <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>
    <load-on-startup>1</load-on-startup>
  </servlet>
 <servlet>
		<servlet-name>fedletapplication</servlet-name>
		<jsp-file>/myapp.jsp</jsp-file>
	</servlet>
	<servlet>
		<servlet-name>fedletSloRedirect</servlet-name>
		<jsp-file>/saml2/jsp/spSingleLogoutRedirect.jsp</jsp-file>
	</servlet>
  <servlet>
    <servlet-name>action</servlet-name>
    <servlet-class>org.apache.struts.action.ActionServlet</servlet-class>
    <init-param>
      <param-name>config</param-name>
      <param-value>/struts-config.xml</param-value>
    </init-param>
    <load-on-startup>0</load-on-startup>
  </servlet>
  <servlet-mapping>
    <servlet-name>Operations</servlet-name>
    <url-pattern>*.htm</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>action</servlet-name>
    <url-pattern>*.do</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
		<servlet-name>fedletapplication</servlet-name>
		<url-pattern>/fedletapplication</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>fedletSloRedirect</servlet-name>
		<url-pattern>/fedletSloRedirect</url-pattern>
	</servlet-mapping>  
	<servlet>
    <servlet-name>FillDropDownServlet</servlet-name>
    <servlet-class>com.ahct.common.servlets.FillDropDownServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>FillDropDownServlet</servlet-name>
    <url-pattern>/FillData</url-pattern>
  </servlet-mapping>
	<filter>
		<filter-name>XSS</filter-name>
		<filter-class>com.ahct.common.filter.XSSFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>XSS</filter-name>
		<url-pattern>*.do</url-pattern>
	</filter-mapping>
	
	<!-- <filter>
		<filter-name>CSRF</filter-name>
		<filter-class>com.ahct.common.filter.CSRFFilter</filter-class>
	</filter>
	
	<filter-mapping>
		<filter-name>CSRF</filter-name>
		<url-pattern>*.do</url-pattern>
	</filter-mapping>	 -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>/index.jsp</welcome-file>
  </welcome-file-list>
  <resource-ref>
    <description>Resource reference to a factory for java.sql.Connection
	    instance for Claim</description>
    <res-ref-name>jdbc/ehfDS</res-ref-name>
    <res-type>javax.sql.DataSource</res-type>
    <res-auth>Container</res-auth>
  </resource-ref>
	<error-page>
		<error-code>403</error-code>
		<location>/common/accessForbidden.jsp</location>
	</error-page>
</web-app>